# Gateway HTTP service configuration. Copy to .env and fill in. NEVER commit .env — MXRPL_ISSUER_SEED
# is a secret. Run: tsx --env-file=.env src/server.ts  (or export these vars).

PORT=8787

# --- Midnight: the deployed PrivateCredentialGateway contract ---
MXRPL_MIDNIGHT_NETWORK=undeployed
MXRPL_NETWORK_ID=undeployed
MXRPL_CONTRACT_ADDRESS=               # deployed contract address (hex)
MXRPL_POLICY_ID=                      # the policy id (Bytes<32> hex)
MXRPL_INDEXER_URI=http://127.0.0.1:8088/api/v3/graphql
MXRPL_INDEXER_WS_URI=ws://127.0.0.1:8088/api/v3/graphql/ws

# --- XRPL (TESTNET ONLY — the service refuses to start on mainnet) ---
MXRPL_XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
MXRPL_CREDENTIAL_ISSUER=              # issuer r-address (MUST match MXRPL_ISSUER_SEED)
MXRPL_CREDENTIAL_TYPE_HEX=            # uppercase hex, e.g. convertStringToHex("ATL_MIDNIGHT_ELIGIBLE_V1")
MXRPL_ISSUER_SEED=                    # SECRET — issuer seed (s...). Never commit. Use KMS/HSM in prod.
# MXRPL_CREDENTIAL_EXPIRATION=        # optional ripple-epoch expiration
# MXRPL_CREDENTIAL_URI_HEX=           # optional public policy URI, uppercase hex

# --- storage + rate limits ---
MXRPL_IDEMPOTENCY_FILE=./gateway-idempotency.json
MXRPL_IP_RATE_MAX=60                  # pre-auth, per caller IP
MXRPL_IP_RATE_WINDOW_MS=60000
MXRPL_SUBJECT_RATE_MAX=20             # post-auth, per XRPL subject
MXRPL_SUBJECT_RATE_WINDOW_MS=60000
MXRPL_TRUST_PROXY=false               # true ONLY behind a trusted reverse proxy (then X-Forwarded-For is honored)
