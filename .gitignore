node_modules/
.env
.env.*
*.seed
*.secret
spike-artifact.json
dist/

# mock issuer / demo outputs (contain synthetic secrets + private bundles)
demo-out/
holder-secret.json
credential-bundle.json

# Compact build output (regenerate with `npm run compile` in the contract package).
# Large proving/verifier keys + ZKIR; bindings are regenerable. The conformance test
# skips gracefully when managed/ is absent.
contracts/*/managed/
apps/e2e-harness/e2e-artifact.json

# Midnight LevelDB private-state store (regenerated per run; contains signing keys + private state — NEVER commit)
apps/e2e-harness/midnight-level-db/
**/midnight-level-db/

# Gateway service secrets + state (never commit)
apps/gateway-service/.env
apps/gateway-service/gateway-idempotency.json
